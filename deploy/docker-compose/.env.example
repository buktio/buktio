# buktio environment — copy to .env (mode 600) and fill in generated secrets.
#
# Generate each secret value with a CSPRNG, e.g.:
#   openssl rand -hex 32      # GARAGE_RPC_SECRET (32-byte hex)
#   openssl rand -base64 32   # tokens / passwords / encryption key
#
# In a real install the buktio CLI / first-run bootstrap generates these with
# Go's crypto/rand; this file is the manual-compose fallback.

BUKTIO_VERSION=dev
# localhost => Caddy internal-CA cert (HTTPS locally). A real domain => Let's Encrypt.
BUKTIO_DOMAIN=localhost
BUKTIO_PUBLIC_URL=https://localhost

# PostgreSQL.
POSTGRES_DB=buktio
POSTGRES_USER=buktio
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# Garage secrets (injected via env; never written into garage.toml).
GARAGE_RPC_SECRET=CHANGE_ME_hex_32_bytes
GARAGE_ADMIN_TOKEN=CHANGE_ME_base64_32_bytes
GARAGE_METRICS_TOKEN=CHANGE_ME_base64_32_bytes

# buktio app secrets.
# KEK that wraps secrets stored in PostgreSQL (envelope encryption). Back this up
# SEPARATELY — losing it makes every stored secret unrecoverable.
BUKTIO_MASTER_KEY=CHANGE_ME_base64_32_bytes

# Externally-reachable S3 host for presigned URLs (S3 subdomain, no path rewrite).
BUKTIO_S3_PUBLIC_ENDPOINT=https://s3.localhost
# Base domain for public bucket websites: https://<bucket>.web.localhost/
BUKTIO_WEB_PUBLIC_DOMAIN=web.localhost
# Storage mode: "managed" (bootstrap single-node Garage) or "external" (connect
# to an operator-owned Garage; also set GARAGE_ADMIN_URL/GARAGE_S3_URL +
# GARAGE_ADMIN_TOKEN, optional BUKTIO_SYSTEM_S3_ACCESS_KEY/SECRET).
BUKTIO_STORAGE_MODE=managed

# Enterprise: Row-Level Security defense-in-depth. When "on", every authenticated
# request runs on a Postgres connection pinned to its org so the migration 0018
# org_isolation policies enforce tenant isolation at the database. To actually take
# effect the app must connect (DATABASE_URL) as the NON-SUPERUSER `buktio_app` role
# (superusers bypass RLS); app-layer scoping remains the primary control. Off by
# default — OSS/Pro behavior is byte-for-byte unchanged.
# BUKTIO_RLS=on

# Optional: host ports for the DEV infra compose (docker-compose.dev.yml).
# Defaults shown; uncomment to override (e.g. if a port is already in use).
# BUKTIO_PG_PORT=5433
# BUKTIO_S3_PORT=3900
# BUKTIO_ADMIN_PORT=3903
