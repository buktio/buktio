# Build output
/bin/
/dist/
*.exe
*.test
*.out
coverage.*

# Go
/vendor/
go.work.sum

# Secrets & local env (NEVER commit)
.env
*.env
!*.env.example
secrets.env
*.key
*.pem
# The license-VERIFICATION public key is not secret — it must be tracked so the
# ee licensing package compiles (it is embedded in every paid binary). The private
# signing key never lives in the repo.
!ee/licensing/pubkey.pem


# Node / Next.js
node_modules/
apps/web/.next/
apps/web/out/
apps/web/.turbo/
*.tsbuildinfo
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*

# Local data volumes / dumps
/data/
*.dump
*.sql.gz

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# compiled binaries accidentally built at repo root (use bin/ instead)
/buktio-api-ee
/buktio-api
/buktio
/buktio-s3proxy
/keygen
